# Environment Configuration
# Set to 'production' for production deployment
NODE_ENV=development
PORT=3000

# MongoDB Configuration
# Replace with your actual MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?

# Application Settings
LOG_LEVEL=debug

# Puppeteer Configuration (Optional)
# Chrome/Chromium browser for PDF generation
# Leave empty to use Puppeteer-managed browser (automatic - recommended)
# Or specify a custom path: C:\Program Files\Google\Chrome\Application\chrome.exe
# PUPPETEER_EXECUTABLE_PATH=
